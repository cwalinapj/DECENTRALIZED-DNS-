# Cluster + RPC
APP_ENV=staging
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=REPLACE_ME_STAGING_RPC_URL

# Core MVP programs (set to staging deployment IDs)
DDNS_PROGRAM_ID=REPLACE_ME_DDNS_PROGRAM_ID
DDNS_REGISTRY_PROGRAM_ID=REPLACE_ME_DDNS_REGISTRY_PROGRAM_ID
DDNS_QUORUM_PROGRAM_ID=REPLACE_ME_DDNS_QUORUM_PROGRAM_ID
DDNS_STAKE_PROGRAM_ID=REPLACE_ME_DDNS_STAKE_PROGRAM_ID
DDNS_NAMES_PROGRAM_ID=REPLACE_ME_DDNS_NAMES_PROGRAM_ID

# Service defaults
GATEWAY_PORT=8054
TOLLBOOTH_PORT=8788
ALLOW_LOCAL_FALLBACK=0
